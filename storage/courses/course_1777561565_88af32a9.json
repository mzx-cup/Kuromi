{
  "courseId": "course_1777561565_88af32a9",
  "title": "MySQL入门实战",
  "outlines": [
    {
      "id": 1,
      "title": "初识数据库",
      "type": "slide",
      "points": 3,
      "key_points": [
        "数据库与文件系统区别及核心优势",
        "关系型数据库模型的基本结构",
        "MySQL服务器安装与环境配置步骤"
      ],
      "description": "通过对比Excel与数据库，讲解数据库基本概念、关系模型及MySQL安装配置流程。"
    },
    {
      "id": 2,
      "title": "库表设计实战",
      "type": "interactive",
      "points": 3,
      "key_points": [
        "CREATE DATABASE/TABLE语句的语法规范",
        "常用数据类型INT/VARCHAR/DATE的选择",
        "主键PRIMARY KEY与非空约束NOT NULL设置"
      ],
      "description": "在可视化界面中模拟创建学生管理数据库，设置字段类型与主键约束。"
    },
    {
      "id": 3,
      "title": "基础查询演练",
      "type": "exercise",
      "points": 3,
      "key_points": [
        "SELECT/FROM基础查询语句结构",
        "WHERE子句条件过滤逻辑运算",
        "ORDER BY排序与LIMIT分页限制"
      ],
      "description": "在代码编辑器中编写SQL语句，实现指定条件的数据检索与排序操作。"
    },
    {
      "id": 4,
      "title": "多表关联原理",
      "type": "diagram",
      "points": 3,
      "key_points": [
        "内连接INNER JOIN交集查询原理",
        "左外连接LEFT JOIN包含主表所有数据",
        "连接条件ON与过滤条件WHERE区别"
      ],
      "description": "利用维恩图动态演示内连接、左外连接与右外连接的数据匹配过程。"
    },
    {
      "id": 5,
      "title": "知识掌握检测",
      "type": "quiz",
      "points": 3,
      "key_points": [
        "SQL语句执行顺序FROM-WHERE-SELECT",
        "GROUP BY分组与HAVING过滤条件",
        "多表连接查询的数据匹配机制"
      ],
      "description": "针对SQL语法顺序、聚合函数执行逻辑及多表连接机制进行测验。"
    },
    {
      "id": 6,
      "title": "电商订单系统",
      "type": "pbl",
      "points": 3,
      "key_points": [
        "E-R图设计与数据库范式规范应用",
        "外键FOREIGN KEY约束与级联操作",
        "复杂业务查询SQL语句编写优化"
      ],
      "description": "设计并实现一个简易电商订单数据库，涵盖用户、商品及订单信息的关联。"
    },
    {
      "id": 7,
      "title": "性能优化技巧",
      "type": "video",
      "points": 3,
      "key_points": [
        "B+Tree索引结构与存储原理",
        "EXPLAIN命令分析执行计划方法",
        "避免全表扫描的索引优化策略"
      ],
      "description": "观看案例演示视频，学习索引原理、执行计划分析及慢查询优化策略。"
    }
  ],
