{
  "courseId": "course_1777562680_bf3a3bf8",
  "title": "Redis核心实战",
  "outlines": [
    {
      "id": 1,
      "title": "Redis核心概念",
      "type": "slide",
      "points": 4,
      "key_points": [
        "Redis是基于内存运行的键值对存储数据库",
        "支持字符串、列表、哈希等多种数据结构",
        "单线程模型保证了高并发下的原子性操作",
        "持久化机制RDB和AOF确保数据安全可靠"
      ],
      "description": "通过幻灯片深入浅出地讲解Redis的基础架构、数据结构特性及其在高性能场景下的核心优势。"
    },
    {
      "id": 2,
      "title": "基础命令实战",
      "type": "code",
      "points": 4,
      "key_points": [
        "使用SET和GET命令进行字符串的存取操作",
        "掌握EXPIRE命令设置键的自动过期时间",
        "利用INCR命令实现原子性的计数器功能",
        "通过KEYS和SCAN命令查找和管理键名"
      ],
      "description": "在在线终端环境中动手实践，执行Set、Get、Hset等常用命令，体验Redis的基本数据操作流程。"
    },
    {
      "id": 3,
      "title": "内存结构图解",
      "type": "diagram",
      "points": 4,
      "key_points": [
        "理解Redis内存中键值对的存储布局方式",
        "演示字典扩容时的渐进式Rehash过程",
        "解析定期删除和惰性删除两种过期策略",
        "对比不同数据类型在内存中的编码效率"
      ],
      "description": "通过可视化架构图展示Redis的内存管理机制、Rehash过程以及过期键的删除策略原理。"
    },
    {
      "id": 4,
      "title": "核心知识测验",
      "type": "quiz",
      "points": 4,
      "key_points": [
        "辨析五种基本数据类型的具体应用场景",
        "考察对单线程模型处理并发能力的理解",
        "比较RDB快照与AOF日志的优缺点差异",
        "验证对Redis原子操作和事务特性的认知"
      ],
      "description": "针对Redis的数据类型特性、线程模型及持久化机制进行选择题测验，检验核心概念掌握程度。"
    },
    {
      "id": 5,
      "title": "缓存穿透模拟",
      "type": "interactive",
      "points": 4,
      "key_points": [
        "模拟高并发请求查询不存在数据的场景",
        "分析缓存穿透对数据库性能造成的压力",
        "演示布隆过滤器的初始化与判断逻辑",
        "对比空值缓存与布隆过滤器的解决方案"
      ],
      "description": "利用交互式模拟器演示缓存穿透现象，并通过动态调整参数观察布隆过滤器的防护效果。"
    },
    {
      "id": 6,
      "title": "缓存一致性策略",
      "type": "exercise",
      "points": 4,
      "key_points": [
        "实践先更新数据库再删除缓存的正确流程",
        "处理并发读写可能导致的数据脏读问题",
        "设置合理的延时双删策略保证最终一致性",
        "评估强一致性与最终一致性的业务取舍"
      ],
      "description": "在预设的读写场景中，通过交互式步骤练习Cache Aside Pattern，正确处理缓存与数据库同步。"
    },
    {
      "id": 7,
      "title": "电商秒杀系统",
      "type": "pbl",
      "points": 4,
      "key_points": [
        "利用Redis预减库存减轻数据库访问压力",
        "使用Lua脚本保证库存扣减的原子性操作",
        "设计分布式锁解决并发环境下的超卖问题",
        "构建消息队列实现异步下单与流量削峰"
      ],
      "description": "基于Redis设计并实现一个高并发电商秒杀系统，解决超卖问题并优化库存扣减性能。"
    },
    {
      "id": 8,
      "title": "集群架构解析",
      "type": "video",
      "points": 4,
      "key_points": [
        "理解Redis Cluster采用的无中心化架构",
        "学习基于哈希槽的数据分片分配算法",
        "掌握主从复制与哨兵机制的故障转移",
        "分析集群扩缩容时的数据迁移流程"
      ],
      "description": "观看Redis Cluster集群搭建与分片原理的教学视频，学习主从切换与数据分片的实现机制。"
    }
  ],
